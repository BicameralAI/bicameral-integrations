    "status": {"type": "string", "enum": ["raw", "linked", "archived"]},
    "candidateExtractionIds": {"type": "array", "items": {"type": "string"}},
    "decisionIds": {"type": "array", "items": {"type": "string"}},
    "capturedAt": {"type": "string"}
  },
  "definitions": {
    "SourceSystemRef": {
      "type": "object",
