{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "ExternalIngestEnvelope",
  "type": "object",
  "required": [
    "content",
    "source_system",
    "source_uri"
  ],
  "properties": {
    "candidate_hints": {
      "default": [],
      "type": "array",
      "items": {
        "$ref": "#/definitions/ExternalCandidateHint"
      }
    },
    "content": {
      "type": "string"
    },
    "content_hash": {
      "type": [
        "string",
        "null"
      ]
    },
    "evidence": {
      "default": [],
      "type": "array",
      "items": {
        "$ref": "#/definitions/ExternalEvidenceItem"
      }
    },
    "redaction_receipt": {
      "anyOf": [
        {
          "$ref": "#/definitions/ExternalRedactionReceipt"
        },
        {
          "type": "null"
        }
      ]
    },
    "source_system": {
      "type": "string"
    },
    "source_uri": {
      "type": "string"
    }
  },
  "definitions": {
    "ExternalCandidateHint": {
      "type": "object",
      "required": [
        "body",
        "title"
      ],
      "properties": {
        "body": {
          "type": "string"
        },
        "labels": {
          "default": [],
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "level": {
          "type": [
            "string",
            "null"
          ]
        },
        "title": {
          "type": "string"
        }
      }
    },
    "ExternalEvidenceItem": {
      "type": "object",
      "required": [
        "excerpt"
      ],
      "properties": {
        "confidence": {
          "type": [
            "number",
            "null"
          ],
          "format": "double"
        },
        "excerpt": {
          "type": "string"
        },
        "span_end": {
          "type": [
            "integer",
            "null"
          ],
          "format": "uint",
          "minimum": 0.0
        },
        "span_start": {
          "type": [
            "integer",
            "null"
          ],
          "format": "uint",
          "minimum": 0.0
        }
      }
    },
    "ExternalRedactionFinding": {
      "type": "object",
      "required": [
        "action",
        "category",
        "count"
      ],
      "properties": {
        "action": {
          "type": "string"
        },
        "category": {
          "type": "string"
        },
        "count": {
          "type": "integer",
          "format": "uint64",
          "minimum": 0.0
        }
      },
      "additionalProperties": false
    },
    "ExternalRedactionReceipt": {
      "type": "object",
      "required": [
        "completed_at",
        "engine",
        "engine_version",
        "input_digest",
        "output_digest",
        "ruleset_digest",
        "ruleset_id",
        "schema_version",
        "structural_fields_preserved"
      ],
      "properties": {
        "completed_at": {
          "type": "string"
        },
        "engine": {
          "type": "string"
        },
        "engine_version": {
          "type": "string"
        },
        "findings": {
          "default": [],
          "type": "array",
          "items": {
            "$ref": "#/definitions/ExternalRedactionFinding"
          }
        },
        "input_digest": {
          "type": "string"
        },
        "output_digest": {
          "type": "string"
        },
        "ruleset_digest": {
          "type": "string"
        },
        "ruleset_id": {
          "type": "string"
        },
        "schema_version": {
          "type": "integer",
          "format": "uint32",
          "minimum": 0.0
        },
        "structural_fields_preserved": {
          "type": "boolean"
        }
      }
    }
  }
}
